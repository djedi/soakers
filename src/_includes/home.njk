<!-- Home Slider -->
<div class="home-slider">
  <div class="slider-area owl-carousel owl-theme">
    <div class="slider-item slider-bg2">
      <div class="d-table">
        <div class="d-table-cell">
          <div class="container">
            <div class="slider-text">
              <h1>Island Spas</h1>
              <p>
                Designed for any lifestyle. Choose from three trim levels — 
                Essential, Luxury, and Elite. Select the perfect size, pick 
                your ideal seat configuration, and choose the trim that best 
                suits your lifestyle, from thoughtful essentials to ultimate 
                indulgence.
              </p>

              <div class="slider-btn">
                <a href="/framed/?url=https://artesianspas.com/island-spas/" class="default-btn1">Explore More</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="slider-item slider-bg3">
      <div class="d-table">
        <div class="d-table-cell">
          <div class="container">
            <div class="slider-text">
              <h1>TidalFit Swim Spas</h1>
              <p>
                A pool, hot tub and aquatic gym all-in-one! Have all the 
                benefits of a full size pool with less cost, less space 
                and less maintenance. It meets the needs of both fitness 
                enthusiasts and those wanting an alternative to a traditional 
                swimming pool for fun and relaxation.
              </p>

              <div class="slider-btn">
                <a href="/framed/?url=https://tidalfit.com/" class="default-btn1">Explore More</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="slider-item slider-bg1">
      <div class="d-table">
        <div class="d-table-cell">
          <div class="container">
            <div class="slider-text">
              <h1>Artesian Elite</h1>
              <p>
                ARTESIAN ELITE features spacious and elegantly designed spas, all equipped 
                with our patented DIRECTFLOW Personal Control® System, allowing for a 
                fully-customizable spa experience.
              </p>

              <div class="slider-btn">
                <a href="/framed/?url=https://artesianspas.com/artesian-elite/" class="default-btn1">Explore More</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- Home Slider End -->

<!-- Why Soakers -->
<section class="service-area pt-100 pb-70">
  <div class="container">
    <div class="scetion-title text-center mb-50">
      <span>Why Choose Us</span>
      <h2>Your Neighborhood Hot Tub Experts</h2>
      <p>
        Family-owned and operated in Midvale, Utah. We don't just sell hot tubs — we service them too.
      </p>
    </div>

    <div class="row text-center">
      <div class="col-lg-3 col-md-6 mb-4">
        <div class="p-4">
          <i class="fas fa-users fa-3x mb-3" style="color: #f27127;"></i>
          <h4>Family Owned</h4>
          <p>Harvey, Wendy, and family have been helping Utahns find their perfect spa for years.</p>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-4">
        <div class="p-4">
          <i class="fas fa-wrench fa-3x mb-3" style="color: #f27127;"></i>
          <h4>Sales &amp; Service</h4>
          <p>We service what we sell — and hot tubs we didn't sell. Repairs, maintenance, and parts.</p>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-4">
        <div class="p-4">
          <i class="fas fa-star fa-3x mb-3" style="color: #f27127;"></i>
          <h4>4.8★ on Google</h4>
          <p>94 reviews and counting. Our customers love us — read what they have to say below.</p>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-4">
        <div class="p-4">
          <i class="fas fa-dollar-sign fa-3x mb-3" style="color: #f27127;"></i>
          <h4>Financing Available</h4>
          <p>Affordable monthly payments through Mountain America Credit Union. Apply in-store or online.</p>
        </div>
      </div>
    </div>
  </div>
</section>
