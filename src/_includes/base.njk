                  MON - SAT (10:00 AM - 5:00 PM)
                </li>
                <li>
                  <a
                    href="https://www.google.com/maps/place/Soakers/@40.6253922,-111.89205,17z/data=!3m1!4b1!4m5!3m4!1s0x875289b056796419:0xf788862c01f371e2!8m2!3d40.6253922!4d-111.8898613"
                    target="_blank"
                  >
                    <i class="fas fa-map-marker-alt"></i>
                    6905 S STATE ST, MIDVALE, UT 84047
                  </a>
                </li>
                <li>
                  <a href="tel:+18018387727">
                    <i class="fas fa-phone-alt"></i>
                    +1 801 838 SPAS (7727)
                  </a>
                </li>
              </ul>
            </div>
          </div>

          <div class="col-lg-3">
            <div class="social-icon">
              <ul>
                <li>
                  <a
                    href="https://www.facebook.com/Soakers-210242449012689"
                    target="_blank"
                  >
                    <i class="fab fa-facebook-f"></i>
                  </a>
                </li>
                <!-- Removed inactive social profiles -->
              </ul>
            </div>
          </div>
        </div>
      </div>
    </header>
    {% endblock %}
    <!-- End Header Area -->

    {% include 'nav-header.njk' %}



    {% block content %}
    {{ content | safe }}
    {% endblock %}



